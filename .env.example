# Copy this file to `.env` and fill in ONE of the two auth methods below.
# `.env` is git-ignored — your credentials never leave this machine.

# Preferred: reuse an existing browser session (Netscape cookies.txt).
# Avoids a password login and login challenges. e.g. a gallery-dl export.
IG_COOKIES_FILE=/path/to/ig_cookies.txt

# Fallback: username/password login (only used when IG_COOKIES_FILE is unset).
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password
